    "ignored_extensions": [
        ".lnk",
        ".ini",
        ".url"
    ],
    "ignored_names": [
        "desktop.ini",
        "Thumbs.db",
        ".DS_Store"
    ],
    "custom_rules": [
        {
            "name": "Notas Fiscais",
            "conditions": {
                "extension": ".pdf",
                "name_contains": "nota"
            },
            "destination": "Notas Fiscais"
        },
        {
            "name": "Screenshots",
            "conditions": {
                "extension": ".png",
                "name_contains": "screenshot"
            },
            "destination": "Screenshots"
        }
    ],
    "monitored_folders": [],
    "organize_mode": "extension",
    "date_subfolder": true,
    "notifications_enabled": true,
    "minimize_to_tray": false
}